{
  "app": {
    "name": "Procurement Suite",
    "description": "Vendor, catalog and purchase-order management with approvals"
  },
  "personas": [
    {
      "id": "requester",
      "name": "Requester",
      "goals": [
        "Raise purchase orders quickly and track them to issuance",
        "See which of my POs are stuck",
        "Understand how much I've spent this period"
      ]
    },
    {
      "id": "approving-manager",
      "name": "Approving Manager",
      "goals": [
        "Clear approvals fast",
        "Watch my team's spend",
        "Spot vendor concentration risk"
      ]
    },
    {
      "id": "finance",
      "name": "Finance",
      "goals": [
        "Pay approved POs on time",
        "Track spend vs budget",
        "Keep vendor data clean for audit"
      ]
    },
    {
      "id": "admin",
      "name": "Admin",
      "goals": [
        "Keep vendor master and catalog accurate",
        "Full visibility of every PO",
        "Govern access and process health"
      ]
    }
  ],
  "journeys": [
    {
      "id": "j-requester",
      "persona": "requester",
      "story": "Requester sees drafts to finish, POs pending approval, and running spend; raises new POs against the catalog."
    },
    {
      "id": "j-approving-manager",
      "persona": "approving-manager",
      "story": "Manager leads with POs awaiting approval, then team spend and top vendors."
    },
    {
      "id": "j-finance",
      "persona": "finance",
      "story": "Finance sees approved-for-payment, budget vs spend, and overdue POs."
    },
    {
      "id": "j-admin",
      "persona": "admin",
      "story": "Admin maintains vendor master and catalog and sees every PO and its status mix."
    }
  ],
  "roles": [
    {
      "name": "Requester"
    },
    {
      "name": "Approving Manager"
    },
    {
      "name": "Finance"
    },
    {
      "name": "Admin"
    }
  ],
