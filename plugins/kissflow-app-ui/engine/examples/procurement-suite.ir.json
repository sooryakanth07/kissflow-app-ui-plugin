  "workflow": {
    "flow": "Purchase Order",
    "steps": [
      {
        "name": "Submit PO",
        "actor": "Requester"
      },
      {
        "name": "Manager Approval",
        "actor": "Approving Manager",
        "decision": [
          "Approve",
          "Reject"
        ]
      },
      {
        "name": "Finance Processing",
        "actor": "Finance"
      },
      {
        "name": "PO Issued & Closed",
        "actor": "Finance"
      }
    ]
  },
