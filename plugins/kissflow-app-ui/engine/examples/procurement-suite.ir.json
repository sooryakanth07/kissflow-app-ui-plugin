      "scope": "all"
    },
    {
      "role": "Admin",
      "model": "Item Catalog",
      "level": "Editable",
      "scope": "all"
    }
  ],
  "pages": [
    {
      "name": "My Procurement",
      "role": "Requester",
      "cards": [
        {
          "label": "My Draft POs",
          "source_flow": "Purchase Order",
          "view": "kpi",
          "scope": "my-items",
          "metric": "count",
          "filter": {
            "status": "Draft"
          }
        },
        {
          "label": "My POs Pending Approval",
          "source_flow": "Purchase Order",
          "view": "list",
          "scope": "my-items",
          "metric": "count",
          "filter": {
            "status": "Pending Manager Approval"
          }
        },
        {
          "label": "My Total Spend",
          "source_flow": "Purchase Order",
          "view": "kpi",
          "scope": "my-items",
          "metric": "sum:Grand Total",
