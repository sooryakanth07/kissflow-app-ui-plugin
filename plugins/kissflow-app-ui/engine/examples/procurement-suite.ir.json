    {
      "role": "Requester",
      "model": "Purchase Order",
      "level": "Editable",
      "scope": "my-items"
    },
    {
      "role": "Approving Manager",
      "model": "Purchase Order",
      "level": "Editable",
      "scope": "my-team"
    },
    {
      "role": "Finance",
      "model": "Purchase Order",
      "level": "Editable",
      "scope": "all"
    },
